# ========================================
# CONFIGURAÇÃO DE AMBIENTE
# ========================================
# production = robô operando em modo REAL com Bybit e Binance
# ATENÇÃO: Sistema sempre opera com contas REAIS!
ENVIRONMENT=production

# ========================================
# RASTREAMENTO DE TENDÊNCIA LONGA (ROI %)
# ========================================
# Ativa a "trava de lucro" somente quando ROI >= este valor (ex: 15 = +15%)
TRAILING_TRIGGER_ROI=15
# Folga (em pontos percentuais) a partir do topo para fechar por reversão (ex: 20 => 80% -> 60%)
TRAILING_REVERSAO_ROI=20
# Piso mínimo de lucro (ROI) após a trava estar ativa (garantia de vitória). Ex: 1 = fecha se cair para +1% ou menos
TRAILING_PROFIT_FLOOR_ROI=1

# ========================================
# GESTÃO DE RISCO — TAMANHO DA POSIÇÃO
# ========================================
# Percentual da banca por ordem (padrão 5% — NÃO usa mínimo da moeda)
RISK_PER_TRADE_PCT=5
# Percentual após STOP_LOSS (padrão 3%)
ENTRY_AFTER_STOP_PCT=3

# ========================================
# INTELIGÊNCIA DE MERCADO (IA INSTITUCIONAL)
# ========================================
# Ativa análise de regime, baleias, notícias e timing
ENABLE_MARKET_INTELLIGENCE=true
# Bloqueia entradas em mercado lateral (range/consolidação)
BLOCK_LATERAL_MARKETS=true
# Usa CoinGecko + Groq/Gemini para sentimento e notícias
ENABLE_NEWS_AI=true

# ========================================
# CONTROLE DE EXECUÇÃO DE ORDENS
# ========================================
# true = executa ordens reais na Bybit/Binance
# false = sistema em modo seguro (não executa ordens)
ALLOW_ORDER_EXECUTION=true

# Habilita trading em conta real
# true = ordens reais ativas (PRODUÇÃO)
# false = ordens bloqueadas (SEGURANÇA)
ALLOW_REAL_TRADING=true

# ⚠️  ATENÇÃO: USE_TESTNET controla se ordens vão para contas reais ou testnet
# false = ordens vão para suas contas REAIS na Bybit/Binance
# true = ordens vão para contas de TESTE (testnet) - não aparecem nas contas reais!
# 🔧 Para operar com dinheiro real, mantenha USE_TESTNET=false
USE_TESTNET=false

# ========================================
# SALDO FICTÍCIO (TREINO/TESTNET)
# ========================================
# Quando USE_TESTNET=true e as chaves não autenticarem (ex.: retCode=10003),
# o dashboard pode usar um saldo fictício para o robô "treinar" sem travar em $0.
# - Se ENABLE_TRAINING_FAKE_BALANCE não for definido, o padrão é:
#   - true em TESTNET
#   - false em MAINNET
ENABLE_TRAINING_FAKE_BALANCE=
# Valor do saldo fictício (USDT)
TRAINING_FAKE_BALANCE_USD=500

# ========================================
# CREDENCIAIS BYBIT
# ========================================
# Obtenha em: https://www.bybit.com/app/user/api-management
# Permissões necessárias: Read Position + Trade Orders
# IMPORTANTE: Desative 2FA na API Key (não na conta)
BYBIT_API_KEY=YOUR_BYBIT_API_KEY
BYBIT_API_SECRET=YOUR_BYBIT_API_SECRET

# ========================================
# TELEGRAM (NOTIFICAÇÕES)
# ========================================
TELEGRAM_TOKEN=YOUR_TELEGRAM_TOKEN
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID

# ========================================
# INTELIGÊNCIA ARTIFICIAL
# ========================================
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GROQ_API_KEY=YOUR_GROQ_API_KEY

# ========================================
# CONFIGURAÇÃO FRONTEND
# ========================================
VITE_API_BASE=http://localhost:5000
# Google Authenticator 2FA — gere com: python -c "import pyotp; print(pyotp.random_base32())"
# Deixe em branco para pular 2FA em ambientes automatizados (Railway / CI).
TOTP_SECRET=
# Em ambientes sem TTY (Railway/Docker), defina também TOTP_CODE com o código atual do app:
TOTP_CODE=

# ========================================
# STREAMLIT WEB INTERFACE
# ========================================
STREAMLIT_SERVER_HEADLESS=true
PORT=8501
